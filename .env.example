# =========================================================
# Adaptive Stealth Network — Environment Variables
# =========================================================

# Database (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./asn_database.db

# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/asn_db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Sing-box
SINGBOX_BINARY=sing-box
SINGBOX_CONFIG_DIR=/tmp/asn_singbox
